      ]
    },
    "assetType": {
      "type": "string",
      "enum": [
        "skill",
        "command",
        "rule",
        "agent",
        "hook"
      ]
    },
    "assetEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "type",
        "tags"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "Relative path to the asset. For skills, points to the skill directory (e.g. skills/my-skill/) so that companion files (references/, scripts/, templates/) are included. For other asset types, points to the file."
        },
        "type": {
          "$ref": "#/$defs/assetType"
        },
        "tags": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/tag"
          }
        },
        "description": {
          "type": "string"
        }
      }
    }
