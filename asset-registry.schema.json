        "spec-kit",
        "starlight",
        "tdd",
        "testing",
        "typescript",
        "validation",
        "versioning",
        "vertical-slices",
        "vitest",
        "vue",
        "web-components",
        "workflow"
      ],
      "properties": {
        "common": {
          "type": "string",
          "const": "Transverse, applicable à tout projet"
        },
        "typescript": {
          "type": "string",
          "const": "TypeScript / JavaScript"
        },
