{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gh-agentic-workflow.local/asset-registry.schema.json",
  "title": "Tagged asset registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "assets",
    "x-tag-descriptions"
  ],
  "properties": {
    "version": {
      "type": "string",
      "description": "Semantic version of the registry file format and content",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "assets": {
      "type": "array",
      "minItems": 0,
      "items": {
        "$ref": "#/$defs/assetEntry"
      }
    },
    "x-tag-descriptions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "architecture",
        "astro",
        "auth",
        "backend",
        "bitbucket",
        "ci-cd",
        "common",
        "css",
        "cursor",
